# ─── URL canônica do site (produção) ──────────────────────────────────────────
# Usada para montar back_urls e notification_url do checkout. Em produção é
# OBRIGATÓRIA — sem ela o app cai no Origin da requisição (não confiável).
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com

# ─── Spotify Web API — Client Credentials ─────────────────────────────────────
# Crie em: https://developer.spotify.com/dashboard
# 1. New App → qualquer nome → Redirect URI: http://localhost:3000
# 2. Copie o Client ID e Client Secret abaixo
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx   # service role — só no servidor, nunca no client

# ─── Mercado Pago (gateway principal) ─────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxx          # token de PRODUÇÃO (não TEST-)
MP_WEBHOOK_SECRET=xxx                # OBRIGATÓRIO — o webhook recusa sem ele
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxx

# ─── Stripe (fallback dormante) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
